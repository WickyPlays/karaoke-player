{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:window:allow-close",
    "global-shortcut:allow-register",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": " $RESOURCE/**/*" }]
    }
  ]
}
